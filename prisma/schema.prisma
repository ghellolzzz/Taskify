generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER TABLE
//////////////////////////////////////////////////////
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Profile
  avatarUrl   String?
  bio         String?
  streakCount Int       @default(0)
  lastActive  DateTime?
  theme       String?
  accentColor String?
  points   Int    @default(0)
  preferredTheme String  @default("theme-classic")

  // Relations
  tasks         Task[]
  categories    Category[]
  comments      Comment[]
  goals         Goal[]
  calendar      CalendarTask[]
  badges        UserBadge[]
  reminders     Reminder[]
  habits        Habit[]
  feedback      Feedback[]
  focusSettings UserFocusSetting[]
  focusSessions FocusSession[]
  teams       TeamMember[] 
  assignedTasks Task[] @relation("TaskAssignees")
  timeEntries TimeEntry[]
  activityLogs ActivityLog[]
  ownedThemes   UserOwnedTheme[]
  friendRequestsSent     Friendship[] @relation("FriendRequester")
  friendRequestsReceived Friendship[] @relation("FriendAddressee")


  passwordResets PasswordReset[]
  communityNotes CommunityNote[]
  noteReactions  NoteReaction[]

  @@map("users")
}

//////////////////////////////////////////////////////
// PASSWORD RESET TABLE
//////////////////////////////////////////////////////
model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

//////////////////////////////////////////////////////
// BADGE TABLE
//////////////////////////////////////////////////////
model Badge {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  description String
  icon        String?

  users UserBadge[]

  @@map("badges")
}

//////////////////////////////////////////////////////
// USER_BADGE TABLE (Many-to-many)
//////////////////////////////////////////////////////
model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

//////////////////////////////////////////////////////
// CATEGORY TABLE
//////////////////////////////////////////////////////
model Category {
  id     Int     @id @default(autoincrement())
  name   String
  color  String?
  userId Int

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]

  @@map("categories")
}

//////////////////////////////////////////////////////
// TASK TABLE
//////////////////////////////////////////////////////
model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      String    @default("Pending")
  priority    String    @default("Medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  userId      Int          
  categoryId  Int?
  teamId      Int? 


  // --- RELATIONS ---
  user        User         @relation(fields: [userId], references: [id])
  category    Category?    @relation(fields: [categoryId], references: [id])
  
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
 assignees   User[]        @relation("TaskAssignees")

  comments    Comment[]
  reminders   Reminder[]
  timeEntries TimeEntry[]

  @@map("tasks")
}

//////////////////////////////////////////////////////
// TIME ENTRY TABLE (time tracking)
//////////////////////////////////////////////////////
model TimeEntry {
  id        Int      @id @default(autoincrement())
  userId    Int
  taskId    Int
  minutes   Int
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

//////////////////////////////////////////////////////
// COMMENT TABLE
//////////////////////////////////////////////////////
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  taskId    Int
  userId    Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("comments")
}

//////////////////////////////////////////////////////
// GOAL TABLE
//////////////////////////////////////////////////////
model Goal {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  category    GoalCategory?
  userId      Int

  user User @relation(fields: [userId], references: [id])

  @@map("goals")
}

enum GoalCategory {
  Finance
  Health
  PersonalGrowth
  Career
  Education
  Fitness
}

//////////////////////////////////////////////////////
// CALENDAR TASK TABLE
//////////////////////////////////////////////////////
model CalendarTask {
  id      Int      @id @default(autoincrement())
  date    DateTime
  content String
  userId  Int

  user User @relation(fields: [userId], references: [id])

  @@map("calendar_tasks")
}

//////////////////////////////////////////////////////
// QUOTES TABLE
//////////////////////////////////////////////////////
model Quote {
  id     Int     @id @default(autoincrement())
  text   String
  author String?
}

//////////////////////////////////////////////////////
// HABITS TABLE
//////////////////////////////////////////////////////
model Habit {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  color         String?
  targetPerWeek Int?
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())

  // NEW
  reminderEnabled Boolean @default(false)
  reminderTime    String?
  reminderRepeat  String  @default("daily")

  logs      HabitLog[]
  reminders Reminder[]
}


model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

//////////////////////////////////////////////////////
// REMINDER TABLE 
//////////////////////////////////////////////////////
model Reminder {
  id     Int  @id @default(autoincrement())
  userId Int
  taskId Int?

  title String
  notes String?

  remindAt   DateTime
  isDone     Boolean  @default(false)
  repeatType String?

  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // NEW (Habit reminders)
  habitId    Int?
  habit      Habit?    @relation(fields: [habitId], references: [id], onDelete: SetNull)
  sourceType String?
  sourceDate DateTime? @db.Date

  @@unique([userId, habitId, sourceType, sourceDate])
  @@map("reminders")
}



//////////////////////////////////////////////////////
// FEEDBACK TABLE
//////////////////////////////////////////////////////
model Feedback {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(50)
  description String   @db.VarChar(1000)
  createdAt   DateTime @default(now())
  userId      Int?

  user User? @relation(fields: [userId], references: [id])

  @@map("feedback")
}

//////////////////////////////////////////////////////
// FOCUS-MODE TABLE
//////////////////////////////////////////////////////
model UserFocusSetting {
  id              Int    @id @default(autoincrement())
  userId          Int    @unique
  preferredTheme  String @default("drink")
  preferredDrink  String @default("coffee")
  backgroundColor String @default("#fdf6e3")

  user User @relation(fields: [userId], references: [id])
}

model FocusSession {
  id              Int      @id @default(autoincrement())
  userId          Int
  durationMinutes Int
  status          String // 'COMPLETED' or 'ABANDONED'
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
// TEAM TABLE 
//////////////////////////////////////////////////////
model Team {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     TeamMember[]
  tasks       Task[]
  activityLogs ActivityLog[]  

  @@map("teams")
}

//////////////////////////////////////////////////////
/// TEAM_MEMBER TABLE 
//////////////////////////////////////////////////////
model TeamMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  role      String   @default("MEMBER") // 'OWNER' or 'MEMBER'
  status    String   @default("PENDING")
  joinedAt  DateTime @default(now())


  user      User     @relation(fields: [userId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId]) // User can't join the same team twice
  @@map("team_members")
}

model Theme {
  id          Int      @id @default(autoincrement())
  name        String
  cost        Int
  cssClass    String
  description String?

  owners      UserOwnedTheme[]
}

model UserOwnedTheme {
  id          Int      @id @default(autoincrement())
  userId      Int
  themeId     Int
  purchasedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  theme       Theme    @relation(fields: [themeId], references: [id])

  @@unique([userId, themeId]) 
}
model ActivityLog {
  id          Int        @id @default(autoincrement())
  teamId      Int
  userId      Int        
  actionType  ActionType 
  details     String?    
  createdAt   DateTime   @default(now())

  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])
  
  // Add a relation back to Team
  @@map("activity_logs")
}

enum ActionType {
  CREATE_TASK
  UPDATE_STATUS
  ADD_MEMBER
  REMOVE_MEMBER
  LEAVE_TEAM
  POST_COMMENT
}

//////////////////////////////////////////////////////
//// CommunityNote TABLE 
//////////////////////////////////////////////////////
model CommunityNote {
  id        Int            @id @default(autoincrement())
  content   String         @db.VarChar(280)
  color     String         @default("yellow")
  createdAt DateTime       @default(now())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions NoteReaction[]

  @@map("community_notes")
}

//////////////////////////////////////////////////////
/// NoteReaction TABLE 
//////////////////////////////////////////////////////
model NoteReaction {
  id     Int           @id @default(autoincrement())
  type   String        // e.g., "HEART", "THUMBS_UP", "SMILE"
  noteId Int
  userId Int
  note   CommunityNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId, type])
  @@map("note_reactions")
}


enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  REMOVED
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester   User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}
