generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER TABLE
//////////////////////////////////////////////////////
model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())

  // Profile
  avatarUrl   String?
  bio         String?
  streakCount Int          @default(0)
  lastActive  DateTime?
  theme       String?      // "light" or "dark"
  accentColor String?      // e.g. #4FD1C5

  // Relations
  tasks       Task[]
  categories  Category[]
  comments    Comment[]
  goals       Goal[]
  calendar    CalendarTask[]
  badges      UserBadge[]
  habits      Habit[]

  @@map("users")
}

//////////////////////////////////////////////////////
// BADGE TABLE
//////////////////////////////////////////////////////
model Badge {
  id          Int      @id @default(autoincrement())
  code        String   @unique     // "ROOKIE", "STREAK_7"
  name        String
  description String
  icon        String?

  users       UserBadge[]

  @@map("badges")
}

//////////////////////////////////////////////////////
// USER_BADGE TABLE (Many-to-many)
//////////////////////////////////////////////////////
model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

//////////////////////////////////////////////////////
// CATEGORY TABLE
//////////////////////////////////////////////////////
model Category {
  id       Int      @id @default(autoincrement())
  name     String
  color    String?
  userId   Int

  user     User     @relation(fields: [userId], references: [id])
  tasks    Task[]

  @@map("categories")
}

//////////////////////////////////////////////////////
// TASK TABLE (Main Feature)
//////////////////////////////////////////////////////
model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  status      String        @default("Pending")     // Pending, Completed
  priority    String        @default("Medium")      // Low, Medium, High
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?    

  userId      Int
  categoryId  Int?

  user        User          @relation(fields: [userId], references: [id])
  category    Category?     @relation(fields: [categoryId], references: [id])
  comments    Comment[]    

  @@map("tasks")
}

//////////////////////////////////////////////////////
// COMMENT TABLE
//////////////////////////////////////////////////////
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  taskId    Int
  userId    Int

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

//////////////////////////////////////////////////////
// GOAL TABLE (User Motivation)
//////////////////////////////////////////////////////
model Goal {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  category    GoalCategory?
  userId      Int

  user        User     @relation(fields: [userId], references: [id])

  @@map("goals")
}

enum GoalCategory {
  Finance
  Health
  PersonalGrowth
  Career
  Education
  Fitness
}


//////////////////////////////////////////////////////
// CALENDAR TASK TABLE (for daily planning)
//////////////////////////////////////////////////////
model CalendarTask {
  id        Int      @id @default(autoincrement())
  date      DateTime // Represents yyyy-mm-dd
  content   String
  userId    Int

  user      User     @relation(fields: [userId], references: [id])

  @@map("calendar_tasks")
}

//////////////////////////////////////////////////////
// QUOTES TABLE 
//////////////////////////////////////////////////////
model Quote {
  id        Int      @id @default(autoincrement())
  text      String
  author    String?
}


model Habit {
  id            Int        @id @default(autoincrement())
  userId        Int
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?    // optional, for future expansion
  color         String?    // hex/accent colour for UI badge
  targetPerWeek Int?       // how many days per week user aims to complete (1–7)
  isArchived    Boolean    @default(false)
  createdAt     DateTime   @default(now())

  logs          HabitLog[]
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime // we store this as the start-of-day for that date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date]) // one check-in per habit per day
}
