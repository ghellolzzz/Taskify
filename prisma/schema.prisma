generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER TABLE
//////////////////////////////////////////////////////
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Profile
  avatarUrl   String?
  bio         String?
  streakCount Int       @default(0)
  lastActive  DateTime?
  theme       String?
  accentColor String?

  // Relations
  tasks         Task[]
  categories    Category[]
  comments      Comment[]
  goals         Goal[]
  calendar      CalendarTask[]
  badges        UserBadge[]
  reminders     Reminder[]
  habits        Habit[]
  feedback      Feedback[]
  focusSettings UserFocusSetting[]
  focusSessions FocusSession[]
  teams       TeamMember[] 
  assignedTasks Task[] @relation("TaskAssignees")

  passwordResets PasswordReset[]

  @@map("users")
}

//////////////////////////////////////////////////////
// PASSWORD RESET TABLE
//////////////////////////////////////////////////////
model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

//////////////////////////////////////////////////////
// BADGE TABLE
//////////////////////////////////////////////////////
model Badge {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  description String
  icon        String?

  users UserBadge[]

  @@map("badges")
}

//////////////////////////////////////////////////////
// USER_BADGE TABLE (Many-to-many)
//////////////////////////////////////////////////////
model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

//////////////////////////////////////////////////////
// CATEGORY TABLE
//////////////////////////////////////////////////////
model Category {
  id     Int     @id @default(autoincrement())
  name   String
  color  String?
  userId Int

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]

  @@map("categories")
}

//////////////////////////////////////////////////////
// TASK TABLE
//////////////////////////////////////////////////////
model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      String    @default("Pending")
  priority    String    @default("Medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  userId      Int          
  categoryId  Int?
  teamId      Int? 


  // --- RELATIONS ---
  user        User         @relation(fields: [userId], references: [id])
  category    Category?    @relation(fields: [categoryId], references: [id])
  
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
 assignees   User[]        @relation("TaskAssignees")

  comments    Comment[]
  reminders   Reminder[]

  @@map("tasks")
}

//////////////////////////////////////////////////////
// COMMENT TABLE
//////////////////////////////////////////////////////
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  taskId    Int
  userId    Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("comments")
}

//////////////////////////////////////////////////////
// GOAL TABLE
//////////////////////////////////////////////////////
model Goal {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  category    GoalCategory?
  userId      Int

  user User @relation(fields: [userId], references: [id])

  @@map("goals")
}

enum GoalCategory {
  Finance
  Health
  PersonalGrowth
  Career
  Education
  Fitness
}

//////////////////////////////////////////////////////
// CALENDAR TASK TABLE
//////////////////////////////////////////////////////
model CalendarTask {
  id      Int      @id @default(autoincrement())
  date    DateTime
  content String
  userId  Int

  user User @relation(fields: [userId], references: [id])

  @@map("calendar_tasks")
}

//////////////////////////////////////////////////////
// QUOTES TABLE
//////////////////////////////////////////////////////
model Quote {
  id     Int     @id @default(autoincrement())
  text   String
  author String?
}

//////////////////////////////////////////////////////
// HABITS TABLE
//////////////////////////////////////////////////////
model Habit {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  color         String?
  targetPerWeek Int?
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())

  logs HabitLog[]
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

//////////////////////////////////////////////////////
// REMINDER TABLE 
//////////////////////////////////////////////////////
model Reminder {
  id     Int  @id @default(autoincrement())
  userId Int
  taskId Int?

  title String
  notes String?

  remindAt   DateTime
  isDone     Boolean  @default(false)
  repeatType String?

  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

//////////////////////////////////////////////////////
// FEEDBACK TABLE
//////////////////////////////////////////////////////
model Feedback {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(50)
  description String   @db.VarChar(1000)
  createdAt   DateTime @default(now())
  userId      Int?

  user User? @relation(fields: [userId], references: [id])

  @@map("feedback")
}

//////////////////////////////////////////////////////
// FOCUS-MODE TABLE
//////////////////////////////////////////////////////
model UserFocusSetting {
  id              Int    @id @default(autoincrement())
  userId          Int    @unique
  preferredTheme  String @default("drink")
  preferredDrink  String @default("coffee")
  backgroundColor String @default("#fdf6e3")

  user User @relation(fields: [userId], references: [id])
}

model FocusSession {
  id              Int      @id @default(autoincrement())
  userId          Int
  durationMinutes Int
  status          String // 'COMPLETED' or 'ABANDONED'
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
// TEAM TABLE 
//////////////////////////////////////////////////////
model Team {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     TeamMember[]
  tasks       Task[]       

  @@map("teams")
}

//////////////////////////////////////////////////////
// TEAM_MEMBER TABLE 
//////////////////////////////////////////////////////
model TeamMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  role      String   @default("MEMBER") // 'OWNER' or 'MEMBER'
  status    String   @default("PENDING")
  joinedAt  DateTime @default(now())


  user      User     @relation(fields: [userId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId]) // User can't join the same team twice
  @@map("team_members")
}

